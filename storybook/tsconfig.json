{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "@/*": ["../src/*"],
      "@aexae/comete-design-system": ["../src/index.ts"],
      "@aexae/comete-design-system/*": ["../src/*"],
      "@storybook/react-vite": ["./node_modules/@storybook/react-vite/dist/index.d.ts"],
      "@storybook/react": ["./node_modules/@storybook/react/dist/index.d.ts"]
    }
  },
  "include": ["../src/**/*", "./**/*", ".storybook/**/*"],
  "exclude": ["node_modules", "storybook-static", "../dist"]
}
