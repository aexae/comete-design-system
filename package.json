{
  "name": "@aexae/comete-design-system",
  "description": "Comète Design System — React Aria + CSS Modules + Design Tokens",
  "author": "aexae",
  "version": "1.0.0-alpha.139",
  "license": "AGPL-3.0-only",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aexae/comete-design-system.git"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "react-aria",
    "css-modules"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "css-types": "tcm src --pattern '**/*.module.css'",
    "css-types:watch": "tcm src --pattern '**/*.module.css' --watch",
    "build": "pnpm css-types && tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stories": "pnpm --filter @aexae/comete-design-system-storybook test",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "react-aria-components": "^1.16.0"
  },
  "peerDependencies": {
    "@aexae/comete-design-tokens": "^0.11.0",
    "@naxit/comete-icons": "^0.6.0",
    "@naxit/comete-illustrations": "^0.1.0-alpha.3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@aexae/comete-design-tokens": "^0.11.6",
    "@eslint/js": "^9.39.4",
    "@internationalized/date": "^3.12.0",
    "@naxit/comete-icons": "latest",
    "@naxit/comete-illustrations": "alpha",
    "@naxit/comete-logos": "0.12.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "default": "./dist/providers/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "default": "./dist/hooks/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ],
      "components": [
        "dist/components/index.d.ts"
      ],
      "providers": [
        "dist/providers/index.d.ts"
      ],
      "hooks": [
        "dist/hooks/index.d.ts"
      ]
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
